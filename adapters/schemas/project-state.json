{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sequence Project State",
  "type": "object",
  "required": [
    "schema_version",
    "state_revision",
    "project_id",
    "project_mode",
    "surface",
    "clip_budget_sec",
    "prompt_budget",
    "story",
    "world_bible",
    "reference_registry",
    "beats",
    "clips",
    "take_history",
    "current_clip_id",
    "canon_revision",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "state_revision": {
      "type": "integer",
      "minimum": 1
    },
    "project_id": {
      "type": "string"
    },
    "project_mode": {
      "enum": [
        "standalone_clip",
        "sequence_project"
      ]
    },
    "surface": {
      "type": "object"
    },
    "clip_budget_sec": {
      "type": [
        "number",
        "null"
      ]
    },
    "prompt_budget": {
      "type": [
        "integer",
        "null"
      ]
    },
    "story": {
      "type": "object"
    },
    "world_bible": {
      "type": "object"
    },
    "reference_registry": {
      "type": "array"
    },
    "beats": {
      "type": "array"
    },
    "clips": {
      "type": "array"
    },
    "take_history": {
      "type": "array"
    },
    "current_clip_id": {
      "type": "string"
    },
    "canon_revision": {
      "type": "integer",
      "minimum": 1
    },
    "updated_at": {
      "type": "string"
    }
  }
}